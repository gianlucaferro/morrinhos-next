# Morrinhos.ai — variáveis de ambiente
# Copie para .env.local e preencha. .env.local fica fora do git.

# ===== Supabase =====
# Pegar em: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service Role Key (server-side only, nunca exposto ao browser)
# Pegar em: Supabase Dashboard → Project → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ===== Site =====
# Em prod: https://morrinhos.ai. Em dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Email transacional (Resend) =====
# Conta exclusiva contato@morrinhos.ai. Configurada via Supabase Edge Functions secrets
# (não usar no front). Documentação: docs/HANDOFF_MORRINHOS.md → seção Email
# RESEND_API_KEY= (configurado via supabase secrets set, não aqui)

# ===== Analytics (opcional, popular quando configurar) =====
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
